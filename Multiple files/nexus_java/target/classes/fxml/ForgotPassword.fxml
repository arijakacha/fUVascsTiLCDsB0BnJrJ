<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.RadialGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:id="rootPane"
           fx:controller="com.nexusplay.controller.ForgotPasswordController"
           styleClass="app-root auth-root" maxWidth="Infinity" maxHeight="Infinity">

    <Pane maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true" pickOnBounds="false">
        <Circle radius="300" opacity="0.13" translateX="-280" translateY="-180">
            <fill>
                <RadialGradient centerX="0.5" centerY="0.5" radius="0.5" proportional="true">
                    <stops>
                        <Stop offset="0" color="#FF4D2E"/>
                        <Stop offset="1" color="#FF4D2E00"/>
                    </stops>
                </RadialGradient>
            </fill>
            <effect>
                <GaussianBlur radius="80.0"/>
            </effect>
        </Circle>
        <Circle radius="240" opacity="0.09" translateX="300" translateY="280">
            <fill>
                <RadialGradient centerX="0.5" centerY="0.5" radius="0.5" proportional="true">
                    <stops>
                        <Stop offset="0" color="#8B0000"/>
                        <Stop offset="1" color="#8B000000"/>
                    </stops>
                </RadialGradient>
            </fill>
            <effect>
                <GaussianBlur radius="60.0"/>
            </effect>
        </Circle>
    </Pane>

    <AnchorPane>
        <ScrollPane fx:id="scrollPane" fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    pannable="true" styleClass="auth-scroll" maxWidth="Infinity" maxHeight="Infinity"
                    AnchorPane.topAnchor="42" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0"
                    AnchorPane.leftAnchor="0">
            <StackPane fx:id="scrollContent" styleClass="scroll-content" maxWidth="Infinity" maxHeight="Infinity"
                       style="-fx-background-color: transparent;" alignment="CENTER">
                <StackPane fx:id="stepStack" styleClass="auth-card-wrap" maxWidth="Infinity">
                    <VBox fx:id="step1" styleClass="auth-card" spacing="10" alignment="CENTER"
                          style="-fx-background-color: rgba(255,255,255,0.03); -fx-border-color: rgba(255,80,46,0.20); -fx-border-radius: 20px; -fx-background-radius: 20px;">
                        <StackPane alignment="CENTER">
                            <VBox.margin>
                                <Insets bottom="16"/>
                            </VBox.margin>
                            <Circle radius="36"
                                    style="-fx-fill: rgba(255,77,46,0.12); -fx-stroke: rgba(255,77,46,0.25); -fx-stroke-width: 1.5;"/>
                            <Label text="✉" style="-fx-font-size: 28px; -fx-text-fill: #FF4D2E;"/>
                        </StackPane>
                        <Text text="ACCOUNT RECOVERY" styleClass="badge-label" textAlignment="CENTER"/>
                        <Text text="Reset your password" styleClass="title-step" textAlignment="CENTER"/>
                        <Text text="Enter your email and we'll send a 6-digit code" styleClass="subtitle-muted"
                              textAlignment="CENTER" wrappingWidth="320"/>
                        <VBox spacing="6" alignment="TOP_LEFT" maxWidth="Infinity">
                            <Label text="Email" styleClass="field-label"/>
                            <TextField fx:id="emailField" promptText="you@example.com"
                                       styleClass="text-field"/>
                        </VBox>
                        <Button fx:id="sendCodeButton" text="SEND CODE" onAction="#handleSendCode"
                                styleClass="btn-primary" maxWidth="Infinity" prefHeight="52"/>
                        <Hyperlink fx:id="backToLoginLink1" text="Back to login" onAction="#handleBackToLogin"
                                   styleClass="hyperlink link-auth"/>
                        <VBox alignment="CENTER" spacing="4">
                            <Text text="© 2024 NexusPlay" styleClass="footer-muted" textAlignment="CENTER"/>
                            <Text text="Connect • Compete • Conquer" styleClass="footer-muted" textAlignment="CENTER"/>
                        </VBox>
                    </VBox>

                    <VBox fx:id="step2" visible="false" managed="false" styleClass="auth-card" spacing="10"
                          alignment="CENTER"
                          style="-fx-background-color: rgba(255,255,255,0.03); -fx-border-color: rgba(255,80,46,0.20); -fx-border-radius: 20px; -fx-background-radius: 20px;">
                        <StackPane alignment="CENTER">
                            <VBox.margin>
                                <Insets bottom="16"/>
                            </VBox.margin>
                            <Circle radius="36"
                                    style="-fx-fill: rgba(45,156,219,0.12); -fx-stroke: rgba(45,156,219,0.25); -fx-stroke-width: 1.5;"/>
                            <Label text="🔐" style="-fx-font-size: 26px;"/>
                        </StackPane>
                        <Text text="VERIFICATION" styleClass="badge-label" textAlignment="CENTER"/>
                        <Text text="Check your email" styleClass="title-step" textAlignment="CENTER"/>
                        <Text fx:id="step2Subtitle" styleClass="subtitle-muted" textAlignment="CENTER"
                              wrappingWidth="320"/>
                        <HBox alignment="CENTER" spacing="8">
                            <TextField fx:id="digit1" styleClass="text-field digit-field"/>
                            <TextField fx:id="digit2" styleClass="text-field digit-field"/>
                            <TextField fx:id="digit3" styleClass="text-field digit-field"/>
                            <TextField fx:id="digit4" styleClass="text-field digit-field"/>
                            <TextField fx:id="digit5" styleClass="text-field digit-field"/>
                            <TextField fx:id="digit6" styleClass="text-field digit-field"/>
                        </HBox>
                        <Button fx:id="verifyCodeButton" text="VERIFY CODE" onAction="#handleVerifyCode"
                                styleClass="btn-primary" maxWidth="Infinity" prefHeight="52"/>
                        <Hyperlink fx:id="resendLink" text="Resend code" onAction="#handleResendCode"
                                   styleClass="hyperlink link-muted"/>
                        <Hyperlink fx:id="backToLoginLink2" text="Back to login" onAction="#handleBackToLogin"
                                   styleClass="hyperlink link-auth"/>
                        <VBox alignment="CENTER" spacing="4">
                            <Text text="© 2024 NexusPlay" styleClass="footer-muted" textAlignment="CENTER"/>
                            <Text text="Connect • Compete • Conquer" styleClass="footer-muted" textAlignment="CENTER"/>
                        </VBox>
                    </VBox>

                    <VBox fx:id="step3" visible="false" managed="false" styleClass="auth-card" spacing="10"
                          alignment="CENTER"
                          style="-fx-background-color: rgba(255,255,255,0.03); -fx-border-color: rgba(255,80,46,0.20); -fx-border-radius: 20px; -fx-background-radius: 20px;">
                        <StackPane alignment="CENTER">
                            <VBox.margin>
                                <Insets bottom="16"/>
                            </VBox.margin>
                            <Circle radius="36"
                                    style="-fx-fill: rgba(255,77,46,0.12); -fx-stroke: rgba(255,77,46,0.25); -fx-stroke-width: 1.5;"/>
                            <Label text="🔑" style="-fx-font-size: 26px;"/>
                        </StackPane>
                        <Text text="NEW PASSWORD" styleClass="badge-label" textAlignment="CENTER"/>
                        <Text text="Set new password" styleClass="title-step" textAlignment="CENTER"/>
                        <StackPane fx:id="step3Inner">
                            <VBox fx:id="step3Form" spacing="10" alignment="CENTER" maxWidth="Infinity">
                                <VBox spacing="6" alignment="TOP_LEFT" maxWidth="Infinity">
                                    <Label text="New Password" styleClass="field-label"/>
                                    <PasswordField fx:id="newPasswordField" promptText="New password"
                                                   styleClass="password-field"/>
                                </VBox>
                                <VBox spacing="6" alignment="TOP_LEFT" maxWidth="Infinity">
                                    <Label text="Confirm Password" styleClass="field-label"/>
                                    <PasswordField fx:id="confirmNewPasswordField" promptText="Confirm new password"
                                                   styleClass="password-field"/>
                                </VBox>
                                <Button fx:id="resetPasswordButton" text="RESET PASSWORD"
                                        onAction="#handleResetPassword" styleClass="btn-primary" maxWidth="Infinity"
                                        prefHeight="52"/>
                                <Hyperlink fx:id="backToLoginLink3" text="Back to login" onAction="#handleBackToLogin"
                                           styleClass="hyperlink link-auth"/>
                            </VBox>
                            <VBox fx:id="successPane" visible="false" managed="false" alignment="CENTER" spacing="12">
                                <Text fx:id="successCheck" text="✓" styleClass="success-check"/>
                                <Text text="Password updated" styleClass="subtitle-muted"/>
                            </VBox>
                        </StackPane>
                        <VBox alignment="CENTER" spacing="4">
                            <Text text="© 2024 NexusPlay" styleClass="footer-muted" textAlignment="CENTER"/>
                            <Text text="Connect • Compete • Conquer" styleClass="footer-muted" textAlignment="CENTER"/>
                        </VBox>
                    </VBox>
                </StackPane>
            </StackPane>
        </ScrollPane>
    </AnchorPane>

    <HBox fx:id="titleBar" styleClass="title-bar" alignment="CENTER_RIGHT" maxWidth="Infinity"
          onMousePressed="#handleTitleBarPressed" onMouseDragged="#handleTitleBarDragged"
          StackPane.alignment="TOP_CENTER">
        <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS"
              style="-fx-padding: 0 0 0 16px;">
            <Label text="NEXUS" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            <Label text="PLAY" style="-fx-text-fill: #FF4D2E; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        </HBox>
        <HBox spacing="8" style="-fx-padding: 10px 12px;">
            <Button fx:id="btnFullscreen" styleClass="win-btn win-btn-fullscreen"
                    onAction="#toggleFullscreen" text="⛶"/>
            <Button fx:id="btnMinimize" styleClass="win-btn win-btn-minimize"
                    onAction="#minimizeWindow" text="−"/>
            <Button fx:id="btnClose" styleClass="win-btn win-btn-close"
                    onAction="#closeWindow" text="✕"/>
        </HBox>
    </HBox>
</StackPane>
