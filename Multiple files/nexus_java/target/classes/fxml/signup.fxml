<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.shape.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nexusplay.controller.SignupController" style="-fx-background-color: #0a0e27;">
    
    <!-- Background Gradient -->
    <Rectangle width="1400" height="900" fill="linear-gradient(to bottom right, #f093fb 0%, #f5576c 50%, #4facfe 100%)" />
    
    <!-- Gaming Pattern Overlay -->
    <Pane opacity="0.1">
        <Circle centerX="150" centerY="150" radius="100" fill="#ffffff" />
        <Circle centerX="1250" centerY="250" radius="80" fill="#ffffff" />
        <Circle centerX="600" centerY="750" radius="120" fill="#ffffff" />
        <Circle centerX="300" centerY="500" radius="90" fill="#ffffff" />
        <Circle centerX="1100" centerY="600" radius="110" fill="#ffffff" />
    </Pane>
    
    <!-- Signup Container -->
    <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background: transparent;" AnchorPane.topAnchor="50" AnchorPane.bottomAnchor="50" AnchorPane.leftAnchor="150" AnchorPane.rightAnchor="150">
        <VBox alignment="CENTER" spacing="25" style="-fx-background-color: rgba(255, 255, 255, 0.95); -fx-background-radius: 20; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 20, 0, 0, 10);">
            
            <!-- Logo and Title -->
            <VBox alignment="CENTER" spacing="15">
                <Text text="🎯" style="-fx-font-size: 48px;" />
                <Text text="JOIN NEXUSPLAY" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: linear-gradient(to right, #f093fb, #f5576c);" />
                <Text text="Create your gaming account" style="-fx-font-size: 16px; -fx-fill: #666;" />
            </VBox>
            
            <!-- User Type Selection -->
            <VBox spacing="10" alignment="CENTER_LEFT" maxWidth="400">
                <Text text="Account Type:" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-fill: #333;" />
                <ComboBox fx:id="userTypeComboBox" style="-fx-background-color: #f8f9fa; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-padding: 12; -fx-font-size: 14px;" maxWidth="400" />
            </VBox>
            
            <!-- Signup Form -->
            <VBox spacing="12" maxWidth="350" style="-fx-padding: 5 0;">
                <VBox spacing="5" alignment="CENTER_LEFT">
                    <Text text="Username" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-fill: #333;" />
                    <TextField fx:id="usernameField" promptText="Choose a unique username" 
                              style="-fx-background-color: #f8f9fa; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-padding: 10; -fx-font-size: 13px;" prefWidth="320" />
                </VBox>
                
                <VBox spacing="5" alignment="CENTER_LEFT">
                    <Text text="Email Address" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-fill: #333;" />
                    <TextField fx:id="emailField" promptText="Enter your email address" 
                              style="-fx-background-color: #f8f9fa; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-padding: 10; -fx-font-size: 13px;" prefWidth="320" />
                </VBox>
                
                <VBox spacing="5" alignment="CENTER_LEFT">
                    <Text text="Password" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-fill: #333;" />
                    <PasswordField fx:id="passwordField" promptText="Create a strong password (min 6 chars)" 
                                  style="-fx-background-color: #f8f9fa; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-padding: 10; -fx-font-size: 13px;" prefWidth="320" />
                </VBox>
                
                <VBox spacing="5" alignment="CENTER_LEFT">
                    <Text text="Confirm Password" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-fill: #333;" />
                    <PasswordField fx:id="confirmPasswordField" promptText="Re-enter your password" 
                                  style="-fx-background-color: #f8f9fa; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-padding: 10; -fx-font-size: 13px;" prefWidth="320" />
                </VBox>
                
                <!-- Terms and Conditions -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <CheckBox fx:id="termsCheckBox" />
                    <Text text="I agree to the Terms of Service" style="-fx-font-size: 11px; -fx-fill: #666;" wrapText="true" />
                </HBox>
                
                <!-- Error Label -->
                <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-wrap-text: true;" visible="false" maxWidth="320" />
                
                <!-- Signup Button -->
                <Button fx:id="signupButton" text="🚀 CREATE ACCOUNT" onAction="#handleSignup" 
                       style="-fx-background-color: linear-gradient(to right, #f093fb, #f5576c); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 6; -fx-padding: 12; -fx-cursor: hand;" prefWidth="320" />
                
                <!-- Back Button -->
                <Button fx:id="backButton" text="← Back to Login" onAction="#handleBack" 
                       style="-fx-background-color: transparent; -fx-text-fill: #f093fb; -fx-font-weight: bold; -fx-font-size: 13px; -fx-border-color: #f093fb; -fx-border-radius: 6; -fx-padding: 10; -fx-cursor: hand;" prefWidth="320" />
            </VBox>
            
        </VBox>
    </ScrollPane>
    
    <!-- Window Controls -->
    <HBox alignment="TOP_RIGHT" spacing="10" AnchorPane.topAnchor="20" AnchorPane.rightAnchor="20">
        <Button text="−" onAction="#handleMinimizeWindow" 
               style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 50; -fx-pref-width: 30; -fx-pref-height: 30; -fx-cursor: hand;" />
        <Button text="✕" onAction="#handleCloseWindow" 
               style="-fx-background-color: rgba(231,76,60,0.8); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 50; -fx-pref-width: 30; -fx-pref-height: 30; -fx-cursor: hand;" />
    </HBox>
    
    <!-- Footer -->
    <VBox alignment="BOTTOM_CENTER" spacing="5" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <Text text="© 2024 NexusPlay Gaming Platform" style="-fx-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;" />
        <Text text="Join the Community • Level Up Your Game" style="-fx-fill: rgba(255,255,255,0.9); -fx-font-size: 14px; -fx-font-weight: bold;" />
    </VBox>
    
</AnchorPane>
