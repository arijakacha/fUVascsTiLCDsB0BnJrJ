<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nexusplay.controller.AdminDashboardController"
            stylesheets="@../css/nexus-theme.css" styleClass="app-root dashboard-root">

    <top>
        <VBox styleClass="dashboard-header">
            <HBox styleClass="dashboard-header-row">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Text text="NEXUS" styleClass="logo-nexus"/>
                    <Text text="PLAY" styleClass="logo-play"/>
                    <Text text="ADMIN" styleClass="section-heading"/>
                </HBox>
                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT" spacing="10">
                    <Button text="Refresh" onAction="#handleRefresh" styleClass="button btn-secondary"/>
                    <Button text="Reports" styleClass="button btn-secondary"/>
                    <Button text="Settings" styleClass="button btn-secondary"/>
                    <Button fx:id="notificationButton" text="🔔" onAction="#handleNotifications" styleClass="button btn-secondary"/>
                    <Label fx:id="notificationBadge" text="0" style="-fx-background-color: #FF4D2E; -fx-background-radius: 10; -fx-text-fill: white; -fx-padding: 2 6; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" styleClass="dashboard-tabpane">
            <Tab fx:id="dashboardTab" text="Dashboard">
                <VBox spacing="20" styleClass="dashboard-content">
                    <Text text="PLATFORM OVERVIEW" styleClass="section-heading"/>
                    <GridPane hgap="16" vgap="16">
                        <HBox styleClass="stat-card" GridPane.rowIndex="0" GridPane.columnIndex="0" spacing="12">
                            <VBox>
                                <Text text="" style="-fx-font-size: 32px;"/>
                                <Text text="TOTAL USERS" styleClass="stat-card-title"/>
                                <Label fx:id="totalUsersLabel" text="0" styleClass="stat-card-value"/>
                            </VBox>
                        </HBox>
                        <HBox styleClass="stat-card" GridPane.rowIndex="0" GridPane.columnIndex="1" spacing="12">
                            <VBox>
                                <Text text="" style="-fx-font-size: 32px;"/>
                                <Text text="TOTAL PLAYERS" styleClass="stat-card-title"/>
                                <Label fx:id="totalPlayersLabel" text="0" styleClass="stat-card-value"/>
                            </VBox>
                        </HBox>
                        <HBox styleClass="stat-card" GridPane.rowIndex="0" GridPane.columnIndex="2" spacing="12">
                            <VBox>
                                <Text text="" style="-fx-font-size: 32px;"/>
                                <Text text="TOTAL TEAMS" styleClass="stat-card-title"/>
                                <Label fx:id="totalTeamsLabel" text="0" styleClass="stat-card-value"/>
                            </VBox>
                        </HBox>
                        <HBox styleClass="stat-card" GridPane.rowIndex="1" GridPane.columnIndex="0" spacing="12">
                            <VBox>
                                <Text text="" style="-fx-font-size: 32px;"/>
                                <Text text="TOTAL GAMES" styleClass="stat-card-title"/>
                                <Label fx:id="totalGamesLabel" text="0" styleClass="stat-card-value"/>
                            </VBox>
                        </HBox>
                        <HBox styleClass="stat-card" GridPane.rowIndex="1" GridPane.columnIndex="1" spacing="12">
                            <VBox>
                                <Text text="" style="-fx-font-size: 32px;"/>
                                <Text text="ACHIEVEMENTS" styleClass="stat-card-title"/>
                                <Label fx:id="totalAchievementsLabel" text="0" styleClass="stat-card-value"/>
                            </VBox>
                        </HBox>
                        <HBox styleClass="stat-card" GridPane.rowIndex="1" GridPane.columnIndex="2" spacing="12">
                            <VBox>
                                <Text text="" style="-fx-font-size: 32px;"/>
                                <Text text="COACHES" styleClass="stat-card-title"/>
                                <Label fx:id="totalMatchesLabel" text="0" styleClass="stat-card-value"/>
                            </VBox>
                        </HBox>
                    </GridPane>
                </VBox>
            </Tab>

            <Tab fx:id="usersTab" text="Users">
                <VBox spacing="10" styleClass="dashboard-content">
                    <HBox spacing="10">
                        <Button text="Add User" onAction="#handleAddUser" styleClass="button btn-primary"/>
                        <Button text="Edit User" onAction="#handleEditUser" styleClass="button btn-secondary"/>
                        <Button text="Delete User" onAction="#handleDeleteUser" styleClass="button btn-secondary"/>
                        <TextField promptText="Search users..." HBox.hgrow="ALWAYS" styleClass="text-field field-dark admin-search"/>
                    </HBox>
                    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" styleClass="table-dark">
                        <columns>
                            <TableColumn fx:id="userIdColumn" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="usernameColumn" text="Username" prefWidth="150"/>
                            <TableColumn fx:id="emailColumn" text="Email" prefWidth="200"/>
                            <TableColumn fx:id="userTypeColumn" text="User Type" prefWidth="100"/>
                            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <Tab fx:id="playersTab" text="Players">
                <VBox spacing="10" styleClass="dashboard-content">
                    <HBox spacing="10">
                        <Button text="Add Player" onAction="#handleAddPlayer" styleClass="button btn-primary"/>
                        <Button text="Edit Player" onAction="#handleEditPlayer" styleClass="button btn-secondary"/>
                        <Button text="Delete Player" onAction="#handleDeletePlayer" styleClass="button btn-secondary"/>
                        <TextField promptText="Search players..." HBox.hgrow="ALWAYS" styleClass="text-field field-dark admin-search"/>
                    </HBox>
                    <TableView fx:id="playersTable" VBox.vgrow="ALWAYS" styleClass="table-dark">
                        <columns>
                            <TableColumn fx:id="playerIdColumn" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="nicknameColumn" text="Nickname" prefWidth="150"/>
                            <TableColumn fx:id="playerGameColumn" text="Game" prefWidth="150"/>
                            <TableColumn fx:id="playerTeamColumn" text="Team" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <Tab fx:id="teamsTab" text="Teams">
                <VBox spacing="10" styleClass="dashboard-content">
                    <HBox spacing="10">
                        <Button text="Create Team" onAction="#handleAddTeam" styleClass="button btn-primary"/>
                        <Button text="Edit Team" onAction="#handleEditTeam" styleClass="button btn-secondary"/>
                        <Button text="Delete Team" onAction="#handleDeleteTeam" styleClass="button btn-secondary"/>
                        <TextField promptText="Search teams..." HBox.hgrow="ALWAYS" styleClass="text-field field-dark admin-search"/>
                    </HBox>
                    <TableView fx:id="teamsTable" VBox.vgrow="ALWAYS" styleClass="table-dark">
                        <columns>
                            <TableColumn fx:id="teamIdColumn" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="teamNameColumn" text="Team Name" prefWidth="200"/>
                            <TableColumn fx:id="teamGameColumn" text="Game" prefWidth="150"/>
                            <TableColumn fx:id="teamCountryColumn" text="Country" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <Tab fx:id="gamesTab" text="Games">
                <VBox spacing="10" styleClass="dashboard-content">
                    <HBox spacing="10">
                        <Button text="Add Game" onAction="#handleAddGame" styleClass="button btn-primary"/>
                        <Button text="Edit Game" onAction="#handleEditGame" styleClass="button btn-secondary"/>
                        <Button text="Delete Game" onAction="#handleDeleteGame" styleClass="button btn-secondary"/>
                        <TextField promptText="Search games..." HBox.hgrow="ALWAYS" styleClass="text-field field-dark admin-search"/>
                    </HBox>
                    <TableView fx:id="gamesTable" VBox.vgrow="ALWAYS" styleClass="table-dark">
                        <columns>
                            <TableColumn fx:id="gameIdColumn" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="gameNameColumn" text="Game Name" prefWidth="200"/>
                            <TableColumn fx:id="releaseYearColumn" text="Release Year" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Achievements">
                <VBox spacing="10" styleClass="dashboard-content">
                    <HBox spacing="10">
                        <Button text="Add Achievement" styleClass="button btn-primary"/>
                        <Button text="Edit Achievement" styleClass="button btn-secondary"/>
                        <Button text="Delete Achievement" styleClass="button btn-secondary"/>
                        <TextField promptText="Search achievements..." HBox.hgrow="ALWAYS" styleClass="text-field field-dark admin-search"/>
                    </HBox>
                    <TableView VBox.vgrow="ALWAYS" styleClass="table-dark">
                        <columns>
                            <TableColumn text="ID" prefWidth="60"/>
                            <TableColumn text="Name" prefWidth="200"/>
                            <TableColumn text="Type" prefWidth="100"/>
                            <TableColumn text="Rarity" prefWidth="100"/>
                            <TableColumn text="Points" prefWidth="80"/>
                            <TableColumn text="Game" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Coaches">
                <VBox spacing="10" styleClass="dashboard-content">
                    <HBox spacing="10">
                        <Button text="Add Coach" styleClass="button btn-primary"/>
                        <Button text="Edit Coach" styleClass="button btn-secondary"/>
                        <Button text="Delete Coach" styleClass="button btn-secondary"/>
                        <TextField promptText="Search coaches..." HBox.hgrow="ALWAYS" styleClass="text-field field-dark admin-search"/>
                    </HBox>
                    <TableView VBox.vgrow="ALWAYS" styleClass="table-dark">
                        <columns>
                            <TableColumn text="ID" prefWidth="60"/>
                            <TableColumn text="Name" prefWidth="200"/>
                            <TableColumn text="Experience" prefWidth="150"/>
                            <TableColumn text="Rating" prefWidth="100"/>
                            <TableColumn text="Price/Session" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Matches">
                <VBox spacing="10" styleClass="dashboard-content">
                    <HBox spacing="10">
                        <Button text="Schedule Match" styleClass="button btn-primary"/>
                        <Button text="Edit Match" styleClass="button btn-secondary"/>
                        <Button text="Delete Match" styleClass="button btn-secondary"/>
                        <TextField promptText="Search matches..." HBox.hgrow="ALWAYS" styleClass="text-field field-dark admin-search"/>
                    </HBox>
                    <TableView VBox.vgrow="ALWAYS" styleClass="table-dark">
                        <columns>
                            <TableColumn text="ID" prefWidth="60"/>
                            <TableColumn text="Game" prefWidth="150"/>
                            <TableColumn text="Team A" prefWidth="150"/>
                            <TableColumn text="Team B" prefWidth="150"/>
                            <TableColumn text="Score" prefWidth="100"/>
                            <TableColumn text="Status" prefWidth="100"/>
                            <TableColumn text="Date" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Statistics">
                <VBox spacing="10" styleClass="dashboard-content">
                    <Text text="ADVANCED STATISTICS" styleClass="section-heading"/>
                    <HBox spacing="16">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <Text text="Player Performance" styleClass="text-on-dark"/>
                            <Text text="Top performing players this month" styleClass="subtitle-muted"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <Text text="Team Rankings" styleClass="text-on-dark"/>
                            <Text text="Current team standings" styleClass="subtitle-muted"/>
                        </VBox>
                    </HBox>
                    <TableView VBox.vgrow="ALWAYS" styleClass="table-dark">
                        <columns>
                            <TableColumn text="Player" prefWidth="150"/>
                            <TableColumn text="Game" prefWidth="100"/>
                            <TableColumn text="K/D Ratio" prefWidth="100"/>
                            <TableColumn text="Win Rate" prefWidth="100"/>
                            <TableColumn text="Matches" prefWidth="100"/>
                            <TableColumn text="ELO Rating" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>
    </center>

    <bottom>
        <HBox styleClass="dashboard-footer" alignment="CENTER_LEFT" spacing="16">
            <Text text="Admin Panel · MySQL" styleClass="dashboard-footer-text"/>
            <HBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT">
                <Text text="NexusPlay v1.0" styleClass="dashboard-footer-text"/>
            </HBox>
        </HBox>
    </bottom>

</BorderPane>
